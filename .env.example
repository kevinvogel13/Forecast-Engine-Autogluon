# Postgres connection string. Required.
DATABASE_URL=postgres://forecast:forecast@postgres:5432/forecast

# Session signing secret. Required. >= 32 chars.
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-openssl-rand-hex-32

# Comma-separated allowed origins for CORS in production.
# Leave empty in dev to reflect any origin.
CORS_ORIGIN=https://forecast.example.com

# Where uploaded datasets live on disk (per-user/per-dataset subdirs).
UPLOAD_DIR=/data/uploads

# Where the engine reads dataset files from. Should equal UPLOAD_DIR
# unless the engine runs out-of-process with its own mount.
STORAGE_PATH=/data/uploads

# Optional. Override the Python binary the sandbox spawns.
PYTHON_BIN=python3

# Optional. Hard wall-clock on each sandbox call, in ms (default 60000).
SANDBOX_TIMEOUT_MS=60000

# Optional. Largest upload accepted, in bytes (default 52428800 = 50 MiB).
MAX_UPLOAD_BYTES=52428800

# Optional. Log level for pino (debug/info/warn/error). Default info in
# prod, debug in dev.
LOG_LEVEL=info

# Application listening port.
PORT=5000
NODE_ENV=production
